{
  "name": "@ziloen/remark-math",
  "version": "0.1.1-unified10",
  "description": "Remark plugin to parse and stringify math with dollar and LaTeX delimiters",
  "keywords": [
    "latex",
    "markdown",
    "math",
    "mdast",
    "remark",
    "unified"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run verify && publint && node scripts/check-package.mjs",
    "verify": "npm run typecheck && npm run test && npm run coverage && npm run build",
    "prepack": "npm run check"
  },
  "dependencies": {
    "@types/hast": "^2.3.10",
    "@types/mdast": "^3.0.15",
    "devlop": "^1.1.0",
    "longest-streak": "^3.1.0",
    "mdast-util-from-markdown": "^1.3.1",
    "mdast-util-to-markdown": "^1.5.0",
    "micromark-factory-space": "^1.1.0",
    "micromark-util-character": "^1.2.0",
    "micromark-util-symbol": "^1.1.0",
    "micromark-util-types": "^1.1.0",
    "unified": "^10.1.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@vitest/coverage-v8": "^4.1.10",
    "micromark": "^3.2.0",
    "publint": "^0.3.21",
    "rehype-stringify": "^9.0.4",
    "remark-parse": "^10.0.2",
    "remark-rehype": "^10.1.0",
    "remark-stringify": "^10.0.3",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
